{% liquid
  assign launcher_label = block.settings.launcher_label | default: 'Shopping Assistant'
  assign header_title = block.settings.header_title | default: 'Shopping Assistant'
  assign assistant_name = block.settings.assistant_name | default: 'Shopping Assistant'
  assign input_placeholder = block.settings.input_placeholder | default: 'Ask about products...'
  assign accent = block.settings.accent | default: '#1f1f1f'
  assign accent_text = block.settings.accent_text | default: '#ffffff'
  assign app_base_url = block.settings.app_base_url | strip
%}

{% if app_base_url != blank %}
  <script
    src="{{ app_base_url }}/api/shopify/theme-embed?shop={{ shop.permanent_domain | url_encode }}&launcherLabel={{ launcher_label | url_encode }}&headerTitle={{ header_title | url_encode }}&assistantName={{ assistant_name | url_encode }}&inputPlaceholder={{ input_placeholder | url_encode }}&accent={{ accent | url_encode }}&accentText={{ accent_text | url_encode }}"
    defer
    data-shop="{{ shop.permanent_domain | escape }}"
  ></script>
{% endif %}

{% schema %}
{
  "name": "Roomie chatbot",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "app_base_url",
      "label": "App base URL",
      "default": "https://rtg-roomie-chatbot.vercel.app"
    },
    {
      "type": "text",
      "id": "assistant_name",
      "label": "Assistant name",
      "default": "Shopping Assistant"
    },
    {
      "type": "text",
      "id": "launcher_label",
      "label": "Launcher label",
      "default": "Shopping Assistant"
    },
    {
      "type": "text",
      "id": "header_title",
      "label": "Header title",
      "default": "Shopping Assistant"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "Ask about products..."
    },
    {
      "type": "color",
      "id": "accent",
      "label": "Accent color",
      "default": "#1f1f1f"
    },
    {
      "type": "color",
      "id": "accent_text",
      "label": "Accent text color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}